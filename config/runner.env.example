# =============================================================================
# runner.env.example — standalone Trial Reel poster (NO database)
#
# Copy to runner.env and fill in. This is ALL the standalone poster needs.
# It deliberately omits every SUPABASE_*, Google Drive, proxy, and identity
# setting — the standalone path talks to the phone and the LLM only.
#
# Load it with scripts/post_one.ps1 (Windows) or scripts/post_one.sh (Linux),
# which parse this file into the process env before invoking the runner.
# =============================================================================

# --- LLM (required) ----------------------------------------------------------
# The Mobilerun manager/executor agents call an OpenAI-compatible endpoint.
# config/mobilerun/config.yaml points provider OpenAILike at ShopAIKey
# (base_url https://api.shopaikey.com/v1); this key authenticates it.
OPENAI_API_KEY=sk-your-shopaikey-token-here

# --- Android tooling (required) ----------------------------------------------
# Path to the adb binary. Use the GenFarmer-bundled adb (35.0.1) if present to
# avoid the adb-server version war that makes TCP devices flap.
ADB_PATH=adb

# ffmpeg / ffprobe are used by video_preparation to transcode to H.264 yuv420p
# (Instagram rejects 10-bit/yuv444 with a black preview). Leave as bare names
# if they are on PATH.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- Mobilerun (required) ----------------------------------------------------
MOBILERUN_CONFIG=config/mobilerun/config.yaml

# --- S3 video source (optional — only for the `s3` CLI commands) -------------
# TWC Storage, S3-compatible, path-style addressing, signature v4. These let the
# runner list video_id folders, read meta.json, and pull videos straight from
# the bucket. Prefixed FERMA_S3_* so they never collide with the main project's
# Supabase S3_* vars.
FERMA_S3_ENDPOINT=https://s3.twcstorage.ru
FERMA_S3_REGION=ru-1
FERMA_S3_BUCKET=neiroslop
FERMA_S3_PREFIX=ferma/
FERMA_S3_ACCESS_KEY=your-access-key-id
FERMA_S3_SECRET_KEY=your-secret-access-key

# --- Optional ----------------------------------------------------------------
# Where downloaded videos (S3/URL source) land before transcode. Defaults to
# the OS temp dir.
# VIDEO_DOWNLOAD_DIR=./.downloads

# Where the agent writes per-run trajectories (for debugging).
MOBILERUN_TRAJECTORIES_DIR=trajectories

# INFO (default) or DEBUG.
LOG_LEVEL=INFO

# Force UTF-8 so emoji in agent logs don't crash on Windows cp1252.
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
