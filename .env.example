# Required keys for Instagram auto-registration
# Copy this to .env and fill in real values

# Gemini LLM (agent brain) — Google AI Studio key
GOOGLE_API_KEY=AIza...

# 5sim.net SMS provider (primary)
FIVESIM_API_KEY=eyJ...

# SMSPool SMS provider (fallback recipe)
SMSPOOL_API_KEY=xF10...

# OPENAI_API_KEY is set automatically from GOOGLE_API_KEY by _run_loop.py
# (Gemini uses the OpenAI-compatible endpoint)

# Optional — paths auto-detected if not set
# ADB_BIN=C:/path/to/adb.exe
# MOBILERUN_CONFIG=config/mobilerun/config.yaml

PYTHONUTF8=1
PYTHONIOENCODING=utf-8
