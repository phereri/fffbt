# fffbt — environment variables (template)
#
# Copy to `.env` and fill in real values locally. Do not commit `.env`.
# Contract and per-variable docs: docs/contracts/environment.md
# `.env*` files are already excluded by .gitignore.

# --- Supabase ----------------------------------------------------------------
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Service role key — server-side only. Never expose to the dashboard frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string used by migrations and scripts.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
SUPABASE_DB_URL=

# --- Google Drive ingestion --------------------------------------------------
# Absolute path to the Google service account JSON used by Drive ingestion.
# Standard Google SDK variable; the JSON file itself must stay out of git.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Device / proxy backends -------------------------------------------------
# Base URL of the GenFarmer service (device profile generation).
GENFARMER_BASE_URL=

# Base URL of the GenRouter service (proxy routing).
GENROUTER_BASE_URL=

# --- Android / Appium --------------------------------------------------------
# Android SDK root. Required for adb and Appium drivers.
ANDROID_HOME=

# Base URL of the Appium server, e.g. http://127.0.0.1:4723
APPIUM_BASE_URL=

# --- Local artifacts ---------------------------------------------------------
# Where per-job screenshots are written. Relative paths resolve from the repo root.
SCREENSHOTS_DIR=./.artifacts/screenshots

# Where per-job logs, dumps, and other artifacts are written.
ARTIFACTS_DIR=./.artifacts

# --- Model provider ----------------------------------------------------------
# Which LLM provider to use: openai | anthropic
MODEL_PROVIDER=openai

# API key for the selected MODEL_PROVIDER.
MODEL_API_KEY=

# --- Logging (optional) ------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
