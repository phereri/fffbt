# fffbt environment template
#
# Copy to `.env` and fill in real values on the target machine.
# Never commit `.env`, service-account JSON, Supabase keys, model keys,
# GenFarmer credentials, proxy credentials, or Instagram credentials.

# =============================================================================
# A. Required for core runtime
# =============================================================================

# Direct Postgres connection string used by runtime CLI and migrations.
# VPS note: Supabase pooler may be required when the direct host is IPv6-only.
# Example shape only:
# postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=

# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase service role key. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# Absolute path to the Google service account JSON used by Drive ingestion.
# The JSON file must stay out of git.
GOOGLE_APPLICATION_CREDENTIALS=

# Ensure `python -m scheduler.cli ...` and worker imports resolve from repo root.
PYTHONPATH=src


# =============================================================================
# B. Required for MobileRun/Mobilerun
# =============================================================================

# Repo-relative Mobilerun MobileConfig.
MOBILERUN_CONFIG=config/mobilerun/config.yaml

# Repo-relative directory where Mobilerun trajectories are written.
MOBILERUN_TRAJECTORIES_DIR=trajectories

# Use MobileRun's TCP device path. This is the primary worker path on the VPS;
# the raw Portal/no-TCP state path can return empty trees on farm phones.
MOBILERUN_USE_TCP=1

# ShopAIKey / Gemini-style OpenAI-compatible key. Placeholder only.
GOOGLE_API_KEY=

# ShopAIKey / Anthropic-compatible key. Placeholder only.
ANTHROPIC_API_KEY=

# Anthropic-compatible ShopAIKey base URL. Do not append /v1 for Anthropic.
ANTHROPIC_BASE_URL=https://api.shopaikey.com

# 0 = Gemini/OpenAI-compatible trajectory path, 1 = Claude trajectory path.
FARM_USE_CLAUDE_TRAJECTORY=0

# Recovery model used by imported farm-standard Mobilerun flows.
FARM_CLAUDE_RECOVERY_MODEL=claude-opus-4-6


# =============================================================================
# C. Android / VPS tools
# =============================================================================

# ADB executable. Use `adb` when platform-tools is on PATH.
ADB_PATH=adb

# ffmpeg tools used by video preparation.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Local runtime artifacts. Relative paths resolve from repo root.
ARTIFACTS_DIR=artifacts


# =============================================================================
# D. Optional / deferred
# =============================================================================

# Personal access token for Supabase Management API fallback scripts.
# Prefer SUPABASE_DB_URL for runtime; use PAT only when direct DB is unavailable.
SUPABASE_PAT=
SUPABASE_PROJECT_REF=

# Google Drive download cache.
VIDEO_DOWNLOAD_DIR=artifacts/videos

# GenFarmer local service. Current MVP should not depend on /automation/apps or /runs.
GENFARMER_BASE_URL=http://127.0.0.1:55554

# GenRouter/proxy work is deferred and not proof-of-posting critical.
GENROUTER_BASE_URL=
PROXY_PROVIDER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Appium fallback, optional for Mobilerun-first validation.
APPIUM_BASE_URL=http://127.0.0.1:4723
ANDROID_HOME=

# Optional screenshot directory override.
SCREENSHOTS_DIR=artifacts/screenshots

# Production hardening / observability.
LOG_LEVEL=info
JOB_HEARTBEAT_INTERVAL_SECONDS=30
JOB_TIMEOUT_SECONDS=900
